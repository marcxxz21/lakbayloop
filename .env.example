NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Realtime map and routing defaults.
NEXT_PUBLIC_MAP_PROVIDER=openstreetmap
NEXT_PUBLIC_OSM_EMBED_BASE=https://www.openstreetmap.org/export/embed.html
NEXT_PUBLIC_DEFAULT_MAP_LAT=14.5995
NEXT_PUBLIC_DEFAULT_MAP_LNG=120.9842

# Server-side data refresh APIs.
# Open-Meteo and the public OSRM demo server do not require API keys.
OPEN_METEO_FORECAST_URL=https://api.open-meteo.com/v1/forecast
OPEN_METEO_AIR_QUALITY_URL=https://air-quality-api.open-meteo.com/v1/air-quality
OSRM_ROUTE_URL=https://router.project-osrm.org/route/v1
